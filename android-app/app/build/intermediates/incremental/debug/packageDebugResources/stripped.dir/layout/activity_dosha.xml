<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="48dp"
            android:visibility="gone" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dosha Analysis"
                android:fontFamily="sans-serif-black"
                android:textSize="28sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manglik &amp; Other Doshas"
                android:fontFamily="sans-serif"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Manglik Status Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardManglik"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manglik Status"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="16dp" />

                <!-- Large Status Badge -->
                <TextView
                    android:id="@+id/tvManglikStatus"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:text="PARTIAL"
                    android:fontFamily="sans-serif-black"
                    android:textSize="18sp"
                    android:textColor="#F59E0B"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_gold_border"
                    android:layout_marginBottom="16dp"
                    tools:text="PARTIAL" />

                <TextView
                    android:id="@+id/tvManglikDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mars in 7th house — partial Manglik dosha"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dosha Factors Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFactors"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dosha Factors"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Kaal Sarp"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvKaalSarpStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pitra Dosha"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvPitraStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFactors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_dosha_factor" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Remedies Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRemedies"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remedies"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <!-- Mantra / Stone / Deity Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Mantra Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_surface_rounded"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OM"
                            android:fontFamily="sans-serif-black"
                            android:textSize="20sp"
                            android:textColor="@color/primary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mantra"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvMantra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Om Angarakaya Namah"
                            android:fontFamily="sans-serif"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Stone Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_surface_rounded"
                        android:padding="12dp"
                        android:layout_marginHorizontal="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💎"
                            android:textSize="20sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gemstone"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvGemstone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Red Coral (Moonga)"
                            android:fontFamily="sans-serif"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Deity Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_surface_rounded"
                        android:padding="12dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🕉"
                            android:textSize="20sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deity"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvDeity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lord Hanuman / Mangal"
                            android:fontFamily="sans-serif"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Additional remedies -->
                <TextView
                    android:id="@+id/tvRemedies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6"
                    tools:text="• Fast on Tuesdays and offer red flowers to Hanuman\n• Recite Hanuman Chalisa daily\n• Wear red coral in gold ring on ring finger on Tuesday morning\n• Donate red lentils and jaggery" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
