<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="48dp"
            android:visibility="gone" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sade Sati"
                android:fontFamily="sans-serif-black"
                android:textSize="28sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saturn's 7.5-Year Transit"
                android:fontFamily="sans-serif"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Current Phase Banner Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPhaseBanner"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Status"
                    android:fontFamily="sans-serif"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="8dp" />

                <!-- Phase Badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvPhaseIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠"
                        android:textSize="24sp"
                        android:textColor="#F59E0B"
                        android:layout_marginEnd="12dp"
                        tools:text="⚠" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPhase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Peak Phase Active"
                            android:fontFamily="sans-serif-black"
                            android:textSize="20sp"
                            android:textColor="#F59E0B"
                            tools:text="Peak Phase Active" />

                        <TextView
                            android:id="@+id/tvPeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 2024 — Jan 2027"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Moon Sign row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_surface_rounded"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moon Sign:"
                        android:fontFamily="sans-serif"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMoonSign"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scorpio (Vrishchik)"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Phase Timeline Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardTimeline"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phase Timeline"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <!-- Rising Phase -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="48dp"
                        android:background="#3B82F6"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rising Phase"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp"
                            android:textColor="#3B82F6" />

                        <TextView
                            android:id="@+id/tvRisingDates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 2021 — Jan 2024"
                            android:fontFamily="sans-serif"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRisingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completed"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="11sp"
                        android:textColor="#10B981"
                        android:background="@drawable/bg_badge_green"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <!-- Peak Phase -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="48dp"
                        android:background="#F59E0B"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Peak Phase"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp"
                            android:textColor="#F59E0B" />

                        <TextView
                            android:id="@+id/tvPeakDates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 2024 — Jan 2027"
                            android:fontFamily="sans-serif"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPeakStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="11sp"
                        android:textColor="#F59E0B"
                        android:background="@drawable/bg_badge_gold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <!-- Setting Phase -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="48dp"
                        android:background="@color/bg_border"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Setting Phase"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp"
                            android:textColor="@color/text_muted" />

                        <TextView
                            android:id="@+id/tvSettingDates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 2027 — Jan 2030"
                            android:fontFamily="sans-serif"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upcoming"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_badge_muted"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Effects Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEffects"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Effects &amp; Interpretation"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvEffects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.6"
                    tools:text="During the Peak Phase of Sade Sati, Saturn directly transits your natal Moon sign. This is a period of karmic reckoning, increased responsibilities, and inner transformation. Career may face obstacles; spiritual practice is strongly recommended." />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Remedies Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRemedies"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remedies"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <!-- Mantra -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="OM"
                        android:fontFamily="sans-serif-black"
                        android:textSize="10sp"
                        android:textColor="@color/primary"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_primary_faint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mantra"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvMantra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Om Sham Shanaishcharaya Namah — 108x daily"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/bg_border" android:layout_marginBottom="12dp"/>

                <!-- Deity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="🕉"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_gold_faint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deity"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvDeity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Worship Lord Shani on Saturdays"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/bg_border" android:layout_marginBottom="12dp"/>

                <!-- Other remedies text -->
                <TextView
                    android:id="@+id/tvRemedies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6"
                    tools:text="• Feed crows and black sesame seeds on Saturdays\n• Donate mustard oil and black cloth\n• Avoid major life decisions in Peak Phase\n• Practice patience and discipline" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
