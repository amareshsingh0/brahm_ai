<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Muhurta Finder"
                android:fontFamily="sans-serif-black"
                android:textSize="28sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find Auspicious Timings"
                android:fontFamily="sans-serif"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Activity Type Card -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Activity"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp" />

                <!-- Activity Chips Horizontal Scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMarriage"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marriage"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTravel"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Travel" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipBusiness"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Business" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipEducation"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Education" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipHealth"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Health" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipProperty"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Property" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVehicle"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vehicle" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipNamkaran"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Namkaran" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipGriha"
                            style="@style/Widget.BrahmAI.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Griha Pravesh" />

                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Date Range Card -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date Range"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- From Date -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.BrahmAI.TextInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="From"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar"
                        android:layout_marginEnd="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- To Date -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.BrahmAI.TextInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="To"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar"
                        android:layout_marginStart="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etToDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Find Button -->
        <Button
            android:id="@+id/btnFindMuhurta"
            style="@style/Widget.BrahmAI.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Find Auspicious Times"
            android:fontFamily="sans-serif-medium"
            android:textSize="15sp"
            android:layout_marginBottom="20dp" />

        <!-- Results count header -->
        <TextView
            android:id="@+id/tvResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:fontFamily="sans-serif-medium"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            tools:text="12 auspicious muhurtas found"
            tools:visibility="visible" />

        <!-- Results Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvMuhurtaList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Results RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMuhurtas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:itemCount="5"
            tools:listitem="@layout/item_muhurta_result" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
