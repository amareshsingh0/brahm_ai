<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="64dp"
            android:src="@drawable/ic_brahm_logo"
            android:contentDescription="Brahm AI logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_2xl"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_tagline"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />

        <!-- Phone input card -->
        <LinearLayout
            android:id="@+id/layoutPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_phone"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPhone"
                style="@style/Widget.BrahmAI.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/phone_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="phone"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_md" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendOtp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="16dp"
                android:text="@string/send_otp"
                android:textSize="@dimen/text_base"
                style="@style/Widget.BrahmAI.Button" />
        </LinearLayout>

        <!-- OTP input card (hidden initially) -->
        <LinearLayout
            android:id="@+id/layoutOtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_otp"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvOtpSentTo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                android:layout_marginBottom="16dp" />

            <!-- 6 OTP boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="6">

                <com.google.android.material.textfield.TextInputEditText android:id="@+id/otp1"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:layout_margin="4dp" android:gravity="center" android:maxLength="1"
                    android:inputType="number" android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_primary" android:background="@drawable/bg_otp_box"
                    android:fontFamily="sans-serif-black" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/otp2"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:layout_margin="4dp" android:gravity="center" android:maxLength="1"
                    android:inputType="number" android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_primary" android:background="@drawable/bg_otp_box"
                    android:fontFamily="sans-serif-black" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/otp3"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:layout_margin="4dp" android:gravity="center" android:maxLength="1"
                    android:inputType="number" android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_primary" android:background="@drawable/bg_otp_box"
                    android:fontFamily="sans-serif-black" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/otp4"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:layout_margin="4dp" android:gravity="center" android:maxLength="1"
                    android:inputType="number" android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_primary" android:background="@drawable/bg_otp_box"
                    android:fontFamily="sans-serif-black" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/otp5"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:layout_margin="4dp" android:gravity="center" android:maxLength="1"
                    android:inputType="number" android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_primary" android:background="@drawable/bg_otp_box"
                    android:fontFamily="sans-serif-black" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/otp6"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:layout_margin="4dp" android:gravity="center" android:maxLength="1"
                    android:inputType="number" android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_primary" android:background="@drawable/bg_otp_box"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyOtp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="16dp"
                android:text="@string/verify_otp"
                style="@style/Widget.BrahmAI.Button" />

            <TextView
                android:id="@+id/tvResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="@string/resend_otp"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_sm"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/error"
            android:textSize="@dimen/text_sm"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Loading -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center_horizontal"
            app:indicatorColor="@color/primary"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
