<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/setup_profile"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_2xl"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:text="Enter your birth details to generate your Kundali"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />

        <!-- Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            style="@style/Widget.BrahmAI.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/full_name_hint"
            app:startIconDrawable="@drawable/ic_person"
            app:startIconTint="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:inputType="textPersonName|textCapWords"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date of Birth -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDob"
            style="@style/Widget.BrahmAI.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/dob_hint"
            app:startIconDrawable="@drawable/ic_calendar"
            app:startIconTint="@color/text_muted"
            app:endIconMode="none">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDob"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:focusable="false"
                android:clickable="true"
                android:textColor="@color/text_primary"
                android:hint="YYYY-MM-DD" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Time of Birth -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTob"
            style="@style/Widget.BrahmAI.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/tob_hint"
            app:startIconDrawable="@drawable/ic_clock"
            app:startIconTint="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTob"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:focusable="false"
                android:clickable="true"
                android:textColor="@color/text_primary"
                android:hint="HH:MM" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Birth Place search -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPlace"
            style="@style/Widget.BrahmAI.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="@string/place_hint"
            app:startIconDrawable="@drawable/ic_location"
            app:startIconTint="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlace"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:hint="@string/search_city" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- City suggestions dropdown -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Lat / Lon / TZ row (auto-filled) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView android:id="@+id/tvLat"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_muted" android:textSize="@dimen/text_xs"
                android:text="Lat: —" />
            <TextView android:id="@+id/tvLon"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_muted" android:textSize="@dimen/text_xs"
                android:text="Lon: —" />
            <TextView android:id="@+id/tvTz"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_muted" android:textSize="@dimen/text_xs"
                android:text="TZ: —" />
        </LinearLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/error"
            android:textSize="@dimen/text_sm"
            android:visibility="gone" />

        <!-- Generate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="8dp"
            android:text="@string/generate_kundali"
            style="@style/Widget.BrahmAI.Button" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:indicatorColor="@color/primary"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
