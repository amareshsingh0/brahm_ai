<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.BrahmAI"
        android:supportsRtl="false"
        android:usesCleartextTraffic="false">

        <!-- Splash -->
        <activity
            android:name=".ui.auth.SplashActivity"
            android:theme="@style/Theme.BrahmAI.Splash"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth -->
        <activity android:name=".ui.auth.LoginActivity"
            android:theme="@style/Theme.BrahmAI.NoBar"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.auth.OnboardingActivity"
            android:theme="@style/Theme.BrahmAI.NoBar"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main (bottom nav host) -->
        <activity android:name=".ui.main.MainActivity"
            android:exported="false" />

        <!-- Secondary screens -->
        <activity android:name=".ui.secondary.GocharActivity" />
        <activity android:name=".ui.secondary.CompatibilityActivity" />
        <activity android:name=".ui.secondary.MuhurtaActivity" />
        <activity android:name=".ui.secondary.SadeSatiActivity" />
        <activity android:name=".ui.secondary.DoshaActivity" />
        <activity android:name=".ui.secondary.GemstoneActivity" />
        <activity android:name=".ui.secondary.KPActivity" />
        <activity android:name=".ui.secondary.PrashnaActivity" />
        <activity android:name=".ui.secondary.VarshpalActivity" />
        <activity android:name=".ui.secondary.RectificationActivity" />
        <activity android:name=".ui.secondary.PalmistryActivity" />
        <activity android:name=".ui.secondary.HoroscopeActivity" />

        <!-- FCM -->
        <service android:name=".utils.BrahmFirebaseService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- File provider for camera -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
