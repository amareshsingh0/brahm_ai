<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KP System"
                android:fontFamily="@font/poppins_bold"
                android:textSize="28sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Krishnamurti Paddhati"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Birth Details"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <!-- Date + Time Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.BrahmAI.TextInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Date of Birth"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar"
                        android:layout_marginEnd="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.BrahmAI.TextInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Birth Time"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_clock"
                        android:layout_marginStart="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Place Input -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.BrahmAI.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Birth Place"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_location"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Generate Button -->
                <Button
                    android:id="@+id/btnGenerate"
                    style="@style/Widget.BrahmAI.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Generate KP Chart"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Lagna Summary Card (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLagna"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lagna Summary"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Lagna Sign -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_surface_rounded"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lagna"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvLagna"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scorpio"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="16sp"
                            android:textColor="@color/primary"
                            tools:text="Scorpio" />
                    </LinearLayout>

                    <!-- Star Lord -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_surface_rounded"
                        android:padding="12dp"
                        android:layout_marginHorizontal="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Star Lord"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvStarLord"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Saturn"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="16sp"
                            android:textColor="@color/primary"
                            tools:text="Saturn" />
                    </LinearLayout>

                    <!-- Sub Lord -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_surface_rounded"
                        android:padding="12dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sub Lord"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvSubLord"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mercury"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="16sp"
                            android:textColor="@color/primary"
                            tools:text="Mercury" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Planets / Cusps Toggle -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabKP"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/bg_surface"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/text_primary"
            app:tabIndicatorColor="@color/primary"
            app:tabIndicatorHeight="3dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Planets" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cusps" />
        </com.google.android.material.tabs.TabLayout>

        <!-- KP Sub-lords Table -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvKPTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            tools:itemCount="9"
            tools:listitem="@layout/item_kp_row" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
