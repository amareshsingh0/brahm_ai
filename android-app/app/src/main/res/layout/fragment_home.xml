<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- Hamburger -->
            <ImageButton
                android:id="@+id/btnOpenDrawer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_menu"
                android:tint="@color/text_secondary"
                android:padding="10dp"
                android:contentDescription="Menu" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/good_morning"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.03" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Namaste"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnNotification"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_bell"
                android:tint="@color/text_secondary"
                android:padding="9dp"
                android:contentDescription="Notifications" />
        </LinearLayout>

        <!-- Today's Energy hero card — gradient -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTodayEnergy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_gradient"
                android:padding="18dp">

                <!-- Label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star"
                        android:tint="@color/accent_gold"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/todays_energy"
                        android:textColor="@color/accent_gold"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Panchang →"
                        android:textColor="@color/primary_light"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Panchang info grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvTithi"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ekadashi" android:textColor="@color/text_primary"
                            android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/tithi" android:textColor="@color/text_muted"
                            android:textSize="10sp" android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="36dp"
                        android:background="@color/hero_border" android:layout_marginHorizontal="8dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvNakshatra"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rohini" android:textColor="@color/text_primary"
                            android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/nakshatra" android:textColor="@color/text_muted"
                            android:textSize="10sp" android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="36dp"
                        android:background="@color/hero_border" android:layout_marginHorizontal="8dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvRahuKaal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="07:30–09:00" android:textColor="@color/error"
                            android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/rahu_kaal" android:textColor="@color/text_muted"
                            android:textSize="10sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Kundali chart preview card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKundaliPreview"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="My Kundali"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvViewChart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_full_chart"
                        android:textColor="@color/primary_light"
                        android:textSize="12sp"
                        android:padding="4dp" />
                </LinearLayout>

                <com.bimoraai.brahm.ui.kundali.KundaliChartView
                    android:id="@+id/miniChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Ask AI shortcut -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAskAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/primary_dim"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="14dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_ai_avatar" />
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_ai_star"
                        android:tint="@color/primary_light" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/ask_brahm_ai"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/primary_light" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick access section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quick Access"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvQuickAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
