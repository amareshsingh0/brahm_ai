<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Varshphal"
                android:fontFamily="@font/poppins_bold"
                android:textSize="28sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solar Return Chart"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solar Return Parameters"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <!-- Year + Location Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.BrahmAI.TextInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.4"
                        android:hint="Year"
                        android:layout_marginEnd="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etYear"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="4"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            tools:text="2026" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.BrahmAI.TextInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:hint="Location"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_location"
                        android:layout_marginStart="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Generate Button -->
                <Button
                    android:id="@+id/btnGenerate"
                    style="@style/Widget.BrahmAI.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Generate Solar Return"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 5-col Stat Grid Card (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStats"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Year Overview"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Year Lord -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year Lord"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:gravity="center"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvYearLord"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sun"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="15sp"
                            android:textColor="@color/primary"
                            android:gravity="center"
                            tools:text="Sun" />
                    </LinearLayout>

                    <!-- Muntha -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Muntha"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:gravity="center"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvMuntha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7H"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="15sp"
                            android:textColor="@color/primary"
                            android:gravity="center"
                            tools:text="7H" />
                    </LinearLayout>

                    <!-- Lagna -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SR Lagna"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:gravity="center"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvSRLagna"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Libra"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="15sp"
                            android:textColor="@color/primary"
                            android:gravity="center"
                            tools:text="Libra" />
                    </LinearLayout>

                    <!-- Varshesha -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Varshesha"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:gravity="center"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvVarshesha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jupiter"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="15sp"
                            android:textColor="@color/primary"
                            android:gravity="center"
                            tools:text="Jupiter" />
                    </LinearLayout>

                    <!-- Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Score"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:gravity="center"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7/10"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="15sp"
                            android:textColor="#10B981"
                            android:gravity="center"
                            tools:text="7/10" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Planet Table Card (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPlanets"
            style="@style/Widget.BrahmAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solar Return Planets"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:layout_marginBottom="12dp" />

                <!-- Table Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_table_header"
                    android:paddingHorizontal="8dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="Planet"
                        android:fontFamily="@font/poppins_semibold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sign"
                        android:fontFamily="@font/poppins_semibold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:text="House"
                        android:fontFamily="@font/poppins_semibold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:text="Nakshatra"
                        android:fontFamily="@font/poppins_semibold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPlanets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="9"
                    tools:listitem="@layout/item_planet_row" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
