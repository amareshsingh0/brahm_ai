<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light theme — Compose handles all styling, XML only needed for system chrome -->
    <style name="Theme.BrahmAI" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">#F7F7F8</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:colorBackground">#F7F7F8</item>
        <item name="android:windowBackground">#F7F7F8</item>
    </style>

    <!-- Splash screen — shows animated icon before Compose loads -->
    <style name="Theme.BrahmAI.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F7F7F8</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_brahm_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BrahmAI</item>
    </style>
</resources>
