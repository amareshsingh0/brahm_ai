<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BrahmAI" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="materialButtonStyle">@style/Widget.BrahmAI.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.BrahmAI.BottomNav</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
    </style>

    <!-- Splash screen -->
    <style name="Theme.BrahmAI.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_brahm_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BrahmAI</item>
    </style>

    <!-- No action bar for auth screens -->
    <style name="Theme.BrahmAI.NoBar" parent="Theme.BrahmAI">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Primary button -->
    <style name="Widget.BrahmAI.Button" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textSize">15sp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Outlined button (alias used in layouts) -->
    <style name="Widget.BrahmAI.ButtonOutlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Outlined button -->
    <style name="Widget.BrahmAI.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Bottom navigation -->
    <style name="Widget.BrahmAI.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_icon_tint</item>
        <item name="itemTextColor">@color/bottom_nav_icon_tint</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.BrahmAI.BottomNav.Indicator</item>
    </style>

    <style name="Widget.BrahmAI.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/bottom_nav_indicator</item>
    </style>

    <!-- Card style -->
    <style name="Widget.BrahmAI.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_surface_3</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/input_bar_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Chip Rashi (zodiac signs) -->
    <style name="Widget.BrahmAI.ChipRashi" parent="Widget.Material3.Chip.Filter">
        <item name="android:textColor">@color/accent_gold</item>
        <item name="chipBackgroundColor">@color/bg_surface_2</item>
        <item name="chipStrokeColor">@color/accent_gold</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Chip -->
    <style name="Widget.BrahmAI.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipBackgroundColor">@color/bg_surface_2</item>
        <item name="chipStrokeColor">@color/bg_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Input field -->
    <style name="Widget.BrahmAI.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_bar_border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="boxBackgroundColor">@color/input_bar_bg</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>

    <!-- Chat input field (pill style) -->
    <style name="Widget.BrahmAI.TextInput.Chat" parent="Widget.BrahmAI.TextInput">
        <item name="boxCornerRadiusTopStart">22dp</item>
        <item name="boxCornerRadiusTopEnd">22dp</item>
        <item name="boxCornerRadiusBottomStart">22dp</item>
        <item name="boxCornerRadiusBottomEnd">22dp</item>
    </style>

    <!-- Nav drawer item text appearance -->
    <style name="TextAppearance.BrahmAI.NavItem" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>
